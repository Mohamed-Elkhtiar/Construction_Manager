<Window x:Class="ConstructionMaterialManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ConstructionMaterialManager"
        xmlns:vm="clr-namespace:ConstructionMaterialManager.ViewModle"
        xmlns:m="clr-namespace:ConstructionMaterialManager.Modle"
        
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800">
    <Window.DataContext>
        <vm:MainWindowVM/>
       

    </Window.DataContext>
    
    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="File">
                <MenuItem Header="New"/>
                <MenuItem Header="Open"/>
                <MenuItem Header="Save"/>
                <Separator/>
                <MenuItem Header="Exit"/>
            </MenuItem>
            <MenuItem Header="Help"/>
        </Menu>
        <UniformGrid Columns="3" DockPanel.Dock="Top" Margin="10">
            <Border BorderBrush="Black" BorderThickness="1" Margin="5">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="CATALOG" FontWeight="Bold" Margin="5"/>
                    <TextBlock 
        Text="{Binding NoOfMaterials, StringFormat={}{0} Materials}"
        Margin="5"
        FontSize="14"
                Foreground="Gray"/>
                </StackPanel>
            </Border>

            <Border BorderBrush="Black" BorderThickness="1" Margin="5">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="ORDERS" FontWeight="Bold" Margin="5"/>
                    <TextBlock Margin="5">
                    <Run Text="{Binding NoOfOrders}"/>
                    <Run Text="{Binding NoPendingOrders, StringFormat={}{0} Pending}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <Border BorderBrush="Black" BorderThickness="1" Margin="5">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="TOTAL SPENT" FontWeight="Bold" Margin="5"/>
                    <TextBlock Text="{Binding TotalSpent, StringFormat={}{0} EGP}" Margin="5" FontSize="14" Foreground="Green"/>
                    <TextBlock Text="This Month" Margin="5"/>
                </StackPanel>
            </Border>
            
            
        </UniformGrid>
        <DataGrid Height="200" DockPanel.Dock="Top" ItemsSource="{Binding Source={x:Static m:AppData.Materials}}" AutoGenerateColumns="False" Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Name" Binding="{Binding Name}"/>
                <DataGridTextColumn Header="Category" Binding="{Binding Category}"/>
                <DataGridTextColumn Header="Unit" Binding="{Binding Unit}"/>
                
                <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat={}{0} EGP}"/>
                <DataGridTextColumn Header="Delete" Binding="{Binding delete}"/>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin=" 0 10">

            <!-- Name -->
            <StackPanel Margin="5">
                <Label >Name</Label>
                <TextBox Text="{Binding AddedMaterial.Name}" Width="150" />
            </StackPanel>

            <!-- Category -->
            <StackPanel Margin="5">
                <Label >Category</Label>
                <ComboBox ItemsSource="{Binding Categories}" 
                  SelectedItem="{Binding AddedMaterial.Category}" 
                  Width="100"/>
            </StackPanel>

            <!-- Unit -->
            <StackPanel Margin="5">
                <Label >Unit</Label>
                <ComboBox ItemsSource="{Binding Units}" 
                  SelectedItem="{Binding AddedMaterial.Unit}" 
                  Width="100"/>
            </StackPanel>

            <!-- Unit Price -->
            <StackPanel Margin="5">
                <Label >Unit Price</Label>
                <TextBox Text="{Binding AddedMaterial.UnitPrice}" Width="100"/>
            </StackPanel>
            <StackPanel Margin="5"  >
                <Button Content="Add" 
            Command="{Binding AddNewMaterialCommand}"
            Padding="10,5"
            Width="80"/>
            </StackPanel>
        </StackPanel>

        <StackPanel Height="40" DockPanel.Dock="Top" Orientation="Horizontal"  Margin="50 10">
            <Button Content="Open Calculator" 
            
            Padding="10,5" Click="Button_Click"
            />

            <Button  Content="Open Orders" Padding="10,5" Click="Open_order_window"
                    ></Button>
        </StackPanel>

        <StatusBar DockPanel.Dock="Bottom" >
            <StatusBarItem>
                <TextBlock Foreground="White" Text="{Binding LastSaved}"/>
            </StatusBarItem>

            <Separator/>

            <StatusBarItem>
                <TextBlock Foreground="White" Text="{Binding TotalMaterials}"/>
            </StatusBarItem>

            <Separator/>

            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Foreground="White" Text="v1.0.0"/>
            </StatusBarItem>
        </StatusBar>


    </DockPanel>
</Window>
