<Window x:Class="ConstructionMaterialManager.CalculatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ConstructionMaterialManager"
        mc:Ignorable="d"
        Title="CalculatorWindow" Height="450" Width="800">
   
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TabControl SelectionChanged="TabSelectionChanged">
            
            <!--concrete-->
            <TabItem Header="Concrete" Width="100">
                <StackPanel Margin="10,0">
                    <!--Element type-->
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Element Type"></Label>
                        <ComboBox x:Name="ElementTypeComboBox" />
                    </StackPanel>
                    <!--Element Length-->
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Element Length"></Label>
                        <TextBox x:Name="ElementLengthTextBox" Width="200" />
                    </StackPanel>
                    <!--Element Width-->
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Element Width"></Label>
                        <TextBox x:Name="ElementWidthTextBox" Width ="200" />
                    </StackPanel>
                    <!--Element Depth-->
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Element Depth/Height"></Label>
                        <TextBox x:Name="ElementDepthTextBox" Width ="200" />
                    </StackPanel>
                    <!--Element Count-->
                    <StackPanel Orientation="Horizontal">
                        <Label Content="Quantity"></Label>
                        <TextBox x:Name="QuantityTextBox" Width ="200" />
                    </StackPanel>

                    <Button Content="Calculate" Width="100" Margin="0,10,0,0" Click="CalculateButton_Click"/>

                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="16" FontWeight="Bold" Margin="0,10,0,0" Text="Volume = "/>
                            <TextBlock x:Name="ResultVolumeTextBlock" FontSize="16" FontWeight="Bold" Margin="0,10,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="16" FontWeight="Bold" Margin="0,10,0,0" Text="Volume with 10% waste = "/>
                            <TextBlock x:Name="ResultWithWasteValueTextBlock" FontSize="16" FontWeight="Bold" Margin="0,10,0,0" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
                
                
            </TabItem>


            <TabItem Header="Steel" Width="100">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Bar Diameter -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Bar Diameter" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbBarDiameter" Grid.Row="0" Grid.Column="1" ItemsSource="{Binding BarDiamters}"  Margin="0,5" SelectionChanged="cmbBarDiameter_SelectionChanged"/>

                    <!-- Bar Length -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Bar Length (m)" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtBarLength" Text="12"  Grid.Row="1" Grid.Column="1" Margin="0,5" TextChanged="txtBarLength_TextChanged"/>
                    <!-- Number of Bars -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Number of Bars" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtNumberOfBars" Grid.Row="2" Grid.Column="1" Margin="0,5" TextChanged="txtNumberOfBars_TextChanged"/>

                    <!-- Calculate Button -->
                    <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2" 
                            Width="200" 
                            Height="30"
                            Content="Calculate" 
                            Margin="0,10" 
                            Click="Btn_CalculateSteel"/>

                    <!-- Result  -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Weight Per bar (kg)" />
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="tbWeightPerBar" />
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Total Weight (Tons)" />
                    <TextBlock Grid.Row="5" Grid.Column="1" x:Name="tbTotalWeight" />
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="With 5% Waste (Tons)" />
                    <TextBlock Grid.Row="6" Grid.Column="1" x:Name="tbWeightWithWaste" />
                </Grid>

            </TabItem>


            <TabItem Header="Paint" Width="100">
                <Grid Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        
                    </Grid.RowDefinitions>

                    <!-- Surface Type -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Surface Type" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbSurfaceType" Grid.Row="0" Grid.Column="1"   Margin="0,5" />

                    <!-- Surface Area -->
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Surface Area (m²)" VerticalAlignment="Center"/>
                    <StackPanel Grid.Row="1" Grid.Column="1" >
                        <StackPanel  Orientation="Horizontal" Margin="0,5">
                            <RadioButton x:Name="rdSurfaceAreabyArea" Content="By Area" Width="100" IsChecked="True" Checked="rdSurfaceAreabyArea_Checked"/>
                            <RadioButton x:Name="rdSurfaceAreabyLengthWidth" Content="By Length and Width" Width="150" Checked="rdSurfaceAreabyLengthWidth_Checked" />
                        </StackPanel>
                        <StackPanel  x:Name="pnlArea" >
                            <Label Content="Area (m²)"/>
                            <TextBox x:Name="txtSurfaceArea"  Margin="0,5" />
                        </StackPanel>
                        <StackPanel  x:Name="pnlLengthWidth"  Visibility="Collapsed">
                            <Label Content="Length (m)"/>
                            <TextBox x:Name="txtLength"  Margin="0,5" />
                            <Label Content="Width (m)"/>
                            <TextBox x:Name="txtWidth"  Margin="0,5" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Number of Coats -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Number of Coats" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbNumberOfCoats" Grid.Row="2" Grid.Column="1" 
                                Margin="0,5"
                                SelectedIndex="0">
                        <ComboBoxItem Content="1"/>
                        <ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="3"/>
                    </ComboBox>
                    <!--Coverage Rate-->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Coverage Rate (m²/litre)" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtPaintCoverage" Grid.Row="3" Grid.Column="1" Margin="0,5" Text="12" />

                    <!-- Calculate Button -->
                    <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" 
             Width="200" 
             Height="30"
             Content="Calculate" 
             Margin="0,10" 
             Click="Btn_CalculatePaint"/>

                    <!-- Result  -->
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Litres (lit)" />
                    <TextBlock x:Name="tbResultLitres" Grid.Row="5" Grid.Column="1"  />
                    
                </Grid>
            </TabItem>


            <TabItem Header="Tiles" Width="100">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <!--Room Length (m) -->
                    <!--TextBox 
                    Positive decimal-->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Room Length (m)" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtRoomLength" Grid.Row="0" Grid.Column="1" Margin="0,5" />

                    <!--Room Width (m) 
                    TextBox 
                    Positive decimal-->

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Room Width (m)" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtRoomWidth" Grid.Row="1" Grid.Column="1" Margin="0,5" />
                    <!--Tile Size 
                    ComboBox 
                    20×20, 30×30, 40×40, 60×60, 80×80 (cm)-->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Tile Size" VerticalAlignment="Center"/>
                    <ComboBox x:Name="cmbTileSize" Grid.Row="2" Grid.Column="1" Margin="0,5" />
                    <!--
                    
                    Waste Percentage 
                    TextBox 
                    Default: 10%, range 5-20%-->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Waste Percentage (%)" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtWastePercentage" Grid.Row="3" Grid.Column="1" Margin="0,5" Text="10" />

                    <!--Calculate Button-->
                    <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" 
                            Width="200" 
                            Height="30"
                            Content="Calculate" 
                            Margin="0,10" 
                            Click="Btn_CalculateTiles"/>

                    <!--Result-->
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="Tiels" />
                    <TextBlock x:Name="tbResultTiles" Grid.Row="5" Grid.Column="1"  />

                </Grid>
            </TabItem>
            
            
        </TabControl>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="150"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="Material"/>
            <ComboBox x:Name="cmbMaterialOrder" Grid.Row="0" Grid.Column="1"   SelectionChanged="cmbMaterialOrder_SelectionChanged" />
            <TextBlock Grid.Row="1" Grid.Column="0" Text="Quantity"/>
            <TextBlock x:Name="tbQuantity" Grid.Row="1" Grid.Column="1" Margin="0,5" />
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Unit Price"/>
            <TextBlock x:Name="tbUnitPrice" Grid.Row="2" Grid.Column="1" Margin="0,5" />
            <TextBlock Grid.Row="3" Grid.Column="0" Text="Total Cost"/>
            <TextBlock x:Name="tbTotalCost" Grid.Row="3" Grid.Column="1" Margin="0,5" />
            <Button Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" 
                    Width="200" 
                    Height="30"
                    Content="Create Order" 
                    Margin="0,10" 
                    Click="Btn_CreateOrder"/>

        </Grid>
        
    </Grid>
</Window>
